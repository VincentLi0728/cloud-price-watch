[Unit]
Description=Cloud Price Watch
After=network.target

[Service]
Type=simple
User=azureuser
Group=azureuser
WorkingDirectory=/opt/cloud-price-watch/current
EnvironmentFile=/opt/cloud-price-watch/shared/.env
ExecStart=/usr/bin/node /opt/cloud-price-watch/current/server.js
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
